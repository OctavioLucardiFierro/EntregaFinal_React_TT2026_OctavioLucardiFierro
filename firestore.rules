rules_version = '2';

// Reglas de seguridad de Cloud Firestore para PRODUCCION.
// Se cargan en Firebase Console -> Firestore Database -> Rules (o con Firebase CLI).
//
// NOTA: el script "npm run seed" corre SIN autenticacion, asi que la carga
// inicial de productos debe hacerse con la base en modo prueba. Una vez cargados
// los datos, aplica estas reglas.
service cloud.firestore {
  match /databases/{database}/documents {

    function estaLogueado() {
      return request.auth != null;
    }

    function esAdmin() {
      return estaLogueado()
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    // Catalogo: todos pueden verlo; solo el admin puede crear/editar/borrar.
    match /productos/{id} {
      allow read: if true;
      allow write: if esAdmin();
    }

    // Perfil de usuario: cada uno gestiona unicamente el suyo.
    match /usuarios/{uid} {
      allow read: if estaLogueado() && request.auth.uid == uid;
      allow create, update: if estaLogueado() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Comentarios: todos los ven; solo logueados publican;
    // el autor (o un admin) puede borrar el suyo.
    match /comentarios/{id} {
      allow read: if true;
      allow create: if estaLogueado();
      allow delete: if estaLogueado()
        && (resource.data.autorUid == request.auth.uid || esAdmin());
      allow update: if false;
    }
  }
}
